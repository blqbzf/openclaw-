<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:NolanWoWLauncher.ViewModels"
             xmlns:converters="clr-namespace:NolanWoWLauncher.Views.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="NolanWoWLauncher.Views.MainWindow"
             MinWidth="800" MinHeight="450"

    <UserControl.Styles>
        <Style Selector="^UserControl">
            <Setter Property="Background" Value="{DynamicResource background.jpg}" />
            <Setter Property="Stretch" Value="UniformToFill" />
        </Style>
    </UserControl.Styles>

    <Grid>
        <!-- 主界面布局 -->
    </Grid>
</UserControl>
