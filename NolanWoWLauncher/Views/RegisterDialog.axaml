<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:NolanWoWLauncher.ViewModels"
        x:Class="NolanWoWLauncher.Views.RegisterDialog"
        x:DataType="vm:MainViewModel"
        Title="注册账号 - 诺兰时光魔兽"
        Width="400" Height="380"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="#1a1a2e">

    <Window.Styles>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="#2d2d44"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style Selector="Button">
            <Setter Property="Background" Value="#3d3d5c"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button:pointerover">
            <Setter Property="Background" Value="#4d4d6c"/>
        </Style>
    </Window.Styles>

    <Grid Margin="25" RowDefinitions="Auto,*,Auto,Auto">
        <TextBlock Grid.Row="0" Text="📝 注册账号" 
                   FontSize="22" FontWeight="Bold" 
                   Foreground="White"
                   HorizontalAlignment="Center" Margin="0,0,0,25" />

        <StackPanel Grid.Row="1" Spacing="15">
            <TextBox Watermark="👤 用户名 (3-16个字符)" 
                     Text="{Binding RegisterUsername}"
                     Height="40"/>
            <TextBox Watermark="🔒 密码 (至少6个字符)" 
                     PasswordChar="●" 
                     Text="{Binding RegisterPassword}"
                     Height="40"/>
            <TextBox Watermark="📧 邮箱 (可选，用于找回密码)" 
                     Text="{Binding RegisterEmail}"
                     Height="40"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" 
                    Spacing="15" HorizontalAlignment="Center" Margin="0,25,0,0">
            <Button Content="✓ 注册" 
                    Click="OnRegisterClick"
                    Width="120" Height="40"
                    Background="#4CAF50"/>
            <Button Content="✕ 取消" 
                    Click="OnCancelClick"
                    Width="120" Height="40"/>
        </StackPanel>

        <TextBlock Grid.Row="3" Text="{Binding StatusMessage}" 
                   Foreground="#ff6b6b" TextWrapping="Wrap" 
                   Margin="0,15,0,0" FontSize="12"/>
    </Grid>
</Window>
