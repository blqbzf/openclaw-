<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:NolanWoWLauncher.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="NolanWoWLauncher.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Icon="/Assets/background.jpg"
        Title="诺兰时光WoW登录器"
        Width="900" Height="600"
        MinWidth="800" MinHeight="450"
        WindowStartupLocation="CenterScreen">

    <Window.Styles>
        <Style Selector="Window">
            <Setter Property="Background">
                <Setter.Value>
                    <ImageBrush Source="/Assets/background.jpg" Stretch="UniformToFill"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style Selector="Button.wow-btn">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Background" Value="#8D6A2B"/>
            <Setter Property="Foreground" Value="#FFF4D3"/>
            <Setter Property="BorderBrush" Value="#E2C77A"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BoxShadow" Value="0 5 0 0 #3B240C, 0 10 28 0 #66000000"/>
            <Setter Property="RenderTransform" Value="translateY(0px)"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.12"/>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.12"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.08"/>
                    <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.08"/>
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Button.wow-btn:pointerover">
            <Setter Property="Background" Value="#A77E35"/>
            <Setter Property="BorderBrush" Value="#F3D892"/>
            <Setter Property="BoxShadow" Value="0 6 0 0 #3B240C, 0 14 34 0 #7A000000"/>
            <Setter Property="RenderTransform" Value="translateY(-1px)"/>
        </Style>

        <Style Selector="Button.wow-btn:pressed">
            <Setter Property="Background" Value="#6F511C"/>
            <Setter Property="BorderBrush" Value="#C6A55D"/>
            <Setter Property="BoxShadow" Value="0 1 0 0 #3B240C, 0 4 12 0 #55000000"/>
            <Setter Property="RenderTransform" Value="translateY(4px)"/>
        </Style>

        <Style Selector="Button.wow-btn.launch-btn">
            <Setter Property="Height" Value="55"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Background" Value="#7B1113"/>
            <Setter Property="BorderBrush" Value="#E8C36F"/>
            <Setter Property="Foreground" Value="#FFF6DA"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BoxShadow" Value="0 6 0 0 #2A0708, 0 16 36 0 #88000000"/>
        </Style>

        <Style Selector="Button.wow-btn.launch-btn:pointerover">
            <Setter Property="Background" Value="#942022"/>
            <Setter Property="BorderBrush" Value="#F4D992"/>
            <Setter Property="BoxShadow" Value="0 7 0 0 #2A0708, 0 18 40 0 #99000000"/>
        </Style>

        <Style Selector="Button.wow-btn.launch-btn:pressed">
            <Setter Property="Background" Value="#5E0D0F"/>
            <Setter Property="BorderBrush" Value="#C7A95D"/>
            <Setter Property="BoxShadow" Value="0 1 0 0 #2A0708, 0 6 14 0 #66000000"/>
        </Style>
    </Window.Styles>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="20" Spacing="10">
            <Button Classes="wow-btn" Content="📁 选择目录" Click="OnSelectClientClick" Width="110"/>
            <Button Classes="wow-btn" Content="📝 注册账号" Click="OnRegisterClick" Width="110"/>
            <Button Classes="wow-btn" Content="🗑️ 清除缓存" Command="{Binding CleanCacheCommand}" Width="110"/>
            <Button Classes="wow-btn" Content="🔄 检查更新" Command="{Binding CheckForUpdatesCommand}" Width="110"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#88000000" Opacity="0.62" CornerRadius="8" Padding="12" Margin="0,0,0,10">
                <TextBlock Text="{Binding StatusMessage}"
                          FontSize="15" Foreground="White"
                          TextWrapping="Wrap" FontWeight="Medium"/>
            </Border>

            <Border Grid.Row="1" Background="#66000000" Opacity="0.48" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                <ScrollViewer>
                    <TextBlock Text="{Binding ServerUpdateInfo}"
                              FontSize="14" Foreground="White"
                              TextWrapping="Wrap"
                              LineHeight="22"/>
                </ScrollViewer>
            </Border>

            <Border Grid.Row="2" Background="#88000000" Opacity="0.62" CornerRadius="8" Padding="12">
                <StackPanel Spacing="5">
                    <TextBlock Text="📂 客户端路径:" Foreground="#aaaaaa" FontSize="12"/>
                    <TextBlock Text="{Binding ClientPath}" Foreground="White" FontSize="13" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Spacing="5" VerticalAlignment="Center" IsVisible="{Binding IsDownloading}">
                <TextBlock Text="{Binding ProgressText}"
                          FontSize="13" Foreground="White"/>
                <ProgressBar Value="{Binding DownloadProgress}"
                            Maximum="100" Height="22"
                            Foreground="#4CAF50"/>
            </StackPanel>

            <Button Grid.Column="1"
                    Classes="wow-btn launch-btn"
                    Content="▶ 启动游戏"
                    Command="{Binding LaunchGameCommand}"
                    Width="160"
                    Margin="10,0,0,0"/>
        </Grid>
    </Grid>
</Window>
