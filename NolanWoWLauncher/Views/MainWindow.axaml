<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:NolanWoWLauncher.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="NolanWoWLauncher.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Icon="/Assets/background.jpg"
        Title="诺兰时光WoW登录器"
        Width="900" Height="600"
        MinWidth="800" MinHeight="450"
        WindowStartupLocation="CenterScreen">

    <Window.Styles>
        <Style Selector="Window">
            <Setter Property="Background">
                <Setter.Value>
                    <ImageBrush Source="/Assets/background.jpg" Stretch="UniformToFill"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style Selector="Button">
            <Setter Property="Background" Value="#2d2d44"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button:pointerover">
            <Setter Property="Background" Value="#3d3d5c"/>
        </Style>
        <Style Selector="Button:pressed">
            <Setter Property="Background" Value="#1d1d2e"/>
        </Style>
    </Window.Styles>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="20" Spacing="10">
            <Button Content="📁 选择目录" Click="OnSelectClientClick" Width="110" Height="38"/>
            <Button Content="📝 注册账号" Click="OnRegisterClick" Width="110" Height="38"/>
            <Button Content="🗑️ 清除缓存" Command="{Binding CleanCacheCommand}" Width="110" Height="38"/>
            <Button Content="🔄 检查更新" Command="{Binding CheckForUpdatesCommand}" Width="110" Height="38"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#88000000" Opacity="0.62" CornerRadius="8" Padding="12" Margin="0,0,0,10">
                <TextBlock Text="{Binding StatusMessage}"
                          FontSize="15" Foreground="White"
                          TextWrapping="Wrap" FontWeight="Medium"/>
            </Border>

            <Border Grid.Row="1" Background="#66000000" Opacity="0.48" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                <ScrollViewer>
                    <TextBlock Text="{Binding ServerUpdateInfo}"
                              FontSize="14" Foreground="White"
                              TextWrapping="Wrap"
                              LineHeight="22"/>
                </ScrollViewer>
            </Border>

            <Border Grid.Row="2" Background="#88000000" Opacity="0.62" CornerRadius="8" Padding="12">
                <StackPanel Spacing="5">
                    <TextBlock Text="📂 客户端路径:" Foreground="#aaaaaa" FontSize="12"/>
                    <TextBlock Text="{Binding ClientPath}" Foreground="White" FontSize="13" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Spacing="5" VerticalAlignment="Center" IsVisible="{Binding IsDownloading}">
                <TextBlock Text="{Binding ProgressText}"
                          FontSize="13" Foreground="White"/>
                <ProgressBar Value="{Binding DownloadProgress}"
                            Maximum="100" Height="22"
                            Foreground="#4CAF50"/>
            </StackPanel>

            <Button Grid.Column="1"
                    Content="▶ 启动游戏"
                    Command="{Binding LaunchGameCommand}"
                    Width="160" Height="55"
                    FontSize="20" FontWeight="Bold"
                    Background="#4CAF50"
                    Foreground="White"
                    CornerRadius="12"
                    Margin="10,0,0,0"/>
        </Grid>
    </Grid>
</Window>
